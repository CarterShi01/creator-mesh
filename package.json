{
  "name": "creator-mesh",
  "version": "0.0.1",
  "type": "module",
  "scripts": {
    "dev": "tsx src/index.ts",
    "build": "tsc",
    "lint": "eslint src",
    "typecheck": "tsc --noEmit -p tsconfig.test.json",
    "test": "vitest run",
    "test:smoke": "vitest run tests/smoke",
    "test:harness": "vitest run tests/harness",
    "verify:harness": "npm run typecheck && npm run test:harness",
    "verify:quick": "npm run typecheck && npm run test:smoke",
    "verify": "npm run typecheck && npm run test",
    "think": "tsx src/cli.ts",
    "runtime": "tsx src/runtime-cli.ts"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "tsx": "^4.0.0",
    "typescript": "^5.0.0",
    "vitest": "^2.0.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.95.1",
    "@langchain/anthropic": "^1.3.29",
    "@langchain/core": "^1.1.46",
    "@langchain/langgraph": "^1.3.0",
    "@notionhq/client": "^5.20.0"
  }
}
